@using System.Globalization

@* Adapted from https://design.tax.service.gov.uk/hmrc-design-patterns/welsh-language-toggle/ *@

@{
    string returnUrl = Context.Request.PathBase + Context.Request.Path + Context.Request.QueryString;
}

@if (CultureInfo.CurrentUICulture.Name == "cy")
{
    <ul class="govuk-service-navigation__list languageSwitch" aria-label="Switcher iaith">
        <li>
            <a asp-page="/ChangeLanguage" asp-route-culture="en-GB" asp-route-returnUrl="@returnUrl" hreflang="en-GB" lang="en-GB" rel="alternate">
                <span class="govuk-visually-hidden">Change the language to English</span>
                <span aria-hidden="true">English</span>
            </a>
        </li>
        <li aria-current="true">Cymraeg</li>
    </ul>
}
else
{
    <ul class="govuk-service-navigation__list languageSwitch" aria-label="Language switcher">
        <li aria-current="true">English</li>
        <li>
            <a asp-page="/ChangeLanguage" asp-route-culture="cy" asp-route-returnUrl="@returnUrl" hreflang="cy" lang="cy" rel="alternate">
                <span class="govuk-visually-hidden">Newid yr iaith ir Gymraeg</span>
                <span aria-hidden="true">Cymraeg</span>
            </a>
        </li>
    </ul>
}
