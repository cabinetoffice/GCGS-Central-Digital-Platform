@using CO.CDP.UserManagement.Shared.Enums
@model CO.CDP.UserManagement.App.Models.UsersViewModel
@inject CO.CDP.UI.Foundation.Services.ISirsiUrlService SirsiUrlService
@{
    ViewData["Title"] = "Manage users";
    var organisationSlug = ViewContext.RouteData.Values["organisationSlug"]?.ToString() ?? "";
    string? organisationBackUrl = null;
    if (Model?.OrganisationGuid.HasValue == true)
    {
        organisationBackUrl = SirsiUrlService.BuildAuthenticatedUrl("/organisation/" + Model.OrganisationGuid.Value);
    }
}

@section BeforeContent {
    @if (!string.IsNullOrEmpty(organisationBackUrl))
    {
        <a href="@organisationBackUrl" class="govuk-back-link">Back</a>
    }
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-xl">@Model.OrganisationName</span>
        <h1 class="govuk-heading-xl">Manage users</h1>
        <p class="govuk-body-l">Add users to your organisation and manage their access to applications.</p>
    </div>
</div>

<div class="govuk-button-group govuk-!-margin-bottom-6">
    <a href="/organisation/@organisationSlug/add-user" class="govuk-button" data-module="govuk-button">Add a user</a>
</div>

<form method="get" aria-label="Search and filter users" class="app-filter-container">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-quarter">
            <div class="govuk-form-group filter-dropdown-wrapper">
                <label class="govuk-label govuk-!-font-weight-bold" for="role-filter">
                    Organisation role
                </label>
                <select class="govuk-select" id="role-filter" name="role">
                    <option value="">All roles</option>
                    <option value="@OrganisationRole.Owner.ToString().ToLower()" selected="@(Model.SelectedRole == OrganisationRole.Owner.ToString().ToLower())">@OrganisationRole.Owner</option>
                    <option value="@OrganisationRole.Admin.ToString().ToLower()" selected="@(Model.SelectedRole == OrganisationRole.Admin.ToString().ToLower())">@OrganisationRole.Admin</option>
                    <option value="@OrganisationRole.Member.ToString().ToLower()" selected="@(Model.SelectedRole == OrganisationRole.Member.ToString().ToLower())">@OrganisationRole.Member</option>
                </select>
            </div>
        </div>
        <div class="govuk-grid-column-one-quarter">
            <div class="govuk-form-group filter-dropdown-wrapper">
                <label class="govuk-label govuk-!-font-weight-bold" for="application-filter">
                    Has access to
                </label>
                <select class="govuk-select" id="application-filter" name="application">
                    <option value="">All applications</option>
                    @foreach (var app in Model.AvailableApplications)
                    {
                        <option value="@app.Slug" selected="@(string.Equals(Model.SelectedApplication, app.Slug, StringComparison.OrdinalIgnoreCase))">@app.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="govuk-grid-column-one-half">
            <div class="govuk-form-group">
                <label class="govuk-label govuk-!-font-weight-bold" for="user-search">
                    Search users
                </label>
                <div class="search-flex-display">
                    <input class="govuk-input search-text-input"
                           id="user-search"
                           name="search"
                           type="text"
                           value="@Model.SearchTerm"
                           placeholder="e.g. name or email">

                    <button type="submit" class="govuk-button search-button govuk-!-width-auto" data-module="govuk-button" id="search-button">
                        <span class="govuk-visually-hidden">Search</span>
                        <svg class="gem-c-search__icon" width="18" height="18" viewBox="0 0 27 27" fill="none"
                             xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                            <circle cx="12.0161" cy="11.0161" r="8.51613" stroke="currentColor" stroke-width="3"></circle>
                            <line x1="17.8668" y1="17.3587" x2="26.4475" y2="25.9393" stroke="currentColor"
                                  stroke-width="3"></line>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@if (Model.TotalCount == 0)
{
    <div class="govuk-inset-text">
        <p>No users found.</p>
        @if (!string.IsNullOrEmpty(Model.SelectedRole) || !string.IsNullOrEmpty(Model.SelectedApplication) || !string.IsNullOrEmpty(Model.SearchTerm))
        {
            <p>Try:</p>
            <ul class="govuk-list govuk-list--bullet">
                <li>checking your spelling</li>
                <li>using different search terms</li>
                <li><a href="?organisation=@organisationSlug" class="govuk-link">clearing the filters</a></li>
            </ul>
        }
        else
        {
            <p><a href="/organisation/@organisationSlug/add-user" class="govuk-link">Add your first user</a> to get started.</p>
        }
    </div>
}
else
{
    <p class="govuk-body">Showing @Model.TotalCount @(Model.TotalCount == 1 ? "user" : "users")</p>

    @foreach (var user in Model.Users)
    {
        <div class="govuk-summary-card govuk-!-margin-bottom-6">
            <div class="govuk-summary-card__title-wrapper">
                <h2 class="govuk-summary-card__title">
                    @{
                        var isPending = user.Status == UserStatus.Pending;
                    }
                    @if (isPending)
                    {
                        @user.Name
                    }
                    else
                    {
                        <a href="/organisation/@organisationSlug/user/@user.Id" class="govuk-link">@user.Name</a>
                    }
                </h2>
                <ul class="govuk-summary-card__actions">
                    <li class="govuk-summary-card__action">
                        <span class="govuk-body-s">@user.Email</span>
                    </li>
                    <li class="govuk-summary-card__action">
                        @if (user.OrganisationRole.HasValue)
                        {
                            var roleTagClass = OrganisationRoleContent.GetTagClass(user.OrganisationRole.Value);
                            <strong class="govuk-tag @roleTagClass">@user.OrganisationRole</strong>
                        }
                        @if (isPending)
                        {
                            <strong class="govuk-tag govuk-tag--yellow govuk-!-margin-left-1">@user.Status</strong>
                        }
                    </li>
                </ul>
            </div>
            <div class="govuk-summary-card__content">
                @if (user.ApplicationAccess.Count == 0)
                {
                    <p class="govuk-body govuk-!-margin-bottom-2">No applications assigned yet</p>
                }
                else
                {
                    <p class="govuk-body-s govuk-!-margin-bottom-2"><strong>Application access:</strong></p>
                    <ul class="govuk-list govuk-list--bullet govuk-body-s govuk-!-margin-bottom-2">
                        @foreach (var app in user.ApplicationAccess)
                        {
                            <li>@app.ApplicationName@(string.IsNullOrEmpty(app.RoleName) ? "" : $": {app.RoleName}")</li>
                        }
                    </ul>
                }

                <p class="govuk-body govuk-!-margin-top-4">
                    @if (!isPending)
                    {
                        <a href="/organisation/@organisationSlug/user/@user.Id" class="govuk-link govuk-!-margin-right-4">View details</a>
                        <a href="/organisation/@organisationSlug/user/@user.Id/application-roles/change" class="govuk-link govuk-!-margin-right-4">Manage application access</a>
                        <a href="/organisation/@organisationSlug/user/@user.Id/organisation-role/change" class="govuk-link">Change organisation role</a>
                    }
                    else if (user.InviteGuid.HasValue)
                    {
                        <a href="/organisation/@organisationSlug/invites/@user.InviteGuid/resend-invite" class="govuk-link govuk-!-margin-right-4">Resend invite</a>
                        <a href="/organisation/@organisationSlug/invites/@user.InviteGuid/application-roles/change" class="govuk-link govuk-!-margin-right-4">Manage application access</a>
                        <a href="/organisation/@organisationSlug/invites/@user.InviteGuid/organisation-role/change" class="govuk-link">Change organisation role</a>
                    }
                </p>
            </div>
        </div>
    }
}

@section Scripts {
    <script nonce-csp>
        document.getElementById('role-filter')?.addEventListener('change', function() {
            this.form.submit();
        });
        document.getElementById('application-filter')?.addEventListener('change', function() {
            this.form.submit();
        });
    </script>
}
