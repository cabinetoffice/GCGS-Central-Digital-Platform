@model CO.CDP.UserManagement.App.Models.InviteCheckAnswersViewModel
@{
    ViewData["Title"] = "Check your answers";
}

@section BeforeContent {
    <a href="/organisation/@Model.OrganisationSlug/add-user/application-roles" class="govuk-back-link">Back</a>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Check your answers</h1>

        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">First name</dt>
                <dd class="govuk-summary-list__value">@Model.FirstName</dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" href="/organisation/@Model.OrganisationSlug/add-user?returnToCheckAnswers=true">
                        Change<span class="govuk-visually-hidden"> first name</span>
                    </a>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Last name</dt>
                <dd class="govuk-summary-list__value">@Model.LastName</dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" href="/organisation/@Model.OrganisationSlug/add-user?returnToCheckAnswers=true">
                        Change<span class="govuk-visually-hidden"> last name</span>
                    </a>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Email address</dt>
                <dd class="govuk-summary-list__value">@Model.Email</dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" href="/organisation/@Model.OrganisationSlug/add-user?returnToCheckAnswers=true">
                        Change<span class="govuk-visually-hidden"> email address</span>
                    </a>
                </dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Organisation role</dt>
                <dd class="govuk-summary-list__value">@Model.OrganisationRole</dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" href="/organisation/@Model.OrganisationSlug/add-user/organisation-role?returnToCheckAnswers=true">
                        Change<span class="govuk-visually-hidden"> organisation role</span>
                    </a>
                </dd>
            </div>
            @foreach (var application in Model.Applications)
            {
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">@application.ApplicationName</dt>
                    <dd class="govuk-summary-list__value">@application.RoleName</dd>
                    <dd class="govuk-summary-list__actions">
                        <a class="govuk-link" href="/organisation/@Model.OrganisationSlug/add-user/application-roles">
                            Change<span class="govuk-visually-hidden"> role for @application.ApplicationName</span>
                        </a>
                    </dd>
                </div>
            }
        </dl>

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="govuk-button-group">
                <button class="govuk-button" data-module="govuk-button">Send invitation</button>
                <a class="govuk-link" href="/organisation/@Model.OrganisationSlug">Cancel</a>
            </div>
        </form>
    </div>
</div>
