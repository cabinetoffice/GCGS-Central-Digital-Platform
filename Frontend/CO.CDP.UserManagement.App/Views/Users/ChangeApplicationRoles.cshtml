@model CO.CDP.UserManagement.App.Models.ChangeUserApplicationRolesViewModel
@{
    ViewData["Title"] = "Change application roles";
}

@section BeforeContent {
    <a href="/organisation/@Model.OrganisationSlug" class="govuk-back-link">Back</a>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <partial name="/Pages/Shared/_ErrorSummary.cshtml" model="ViewData.ModelState" />

        <div class="app-filter-container govuk-!-margin-bottom-6">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">@Model.UserDisplayName</h2>
            <p class="govuk-body govuk-!-margin-bottom-3">@Model.Email</p>
            <div>
                <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">Current access:</p>
                @if (Model.Applications.Count == 0)
                {
                    <p class="govuk-body govuk-!-margin-bottom-0">No current application access.</p>
                }
                else
                {
                    <div>
                        @foreach (var app in Model.Applications)
                        {
                            var roleName = app.Roles.Where(r => r.Id == app.SelectedRoleId).Select(r => r.Name).FirstOrDefault();
                            <span class="govuk-tag govuk-tag--purple govuk-!-margin-right-1 govuk-!-margin-bottom-1">
                                @(string.IsNullOrEmpty(roleName) ? app.ApplicationName : $"{app.ApplicationName} ({roleName})")
                            </span>
                        }
                    </div>
                }
            </div>
        </div>

        <h1 class="govuk-heading-xl">Select the application roles the user should have access to</h1>
        <p class="govuk-body">Select which role this user should have for each application they are assigned to.</p>

        @{
            var hasApplicationsError = ViewData.ModelState.ContainsKey("Applications") &&
                                       ViewData.ModelState["Applications"]?.Errors.Count > 0;
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div id="Applications" class="govuk-form-group @(hasApplicationsError ? "govuk-form-group--error" : "")">
                @if (hasApplicationsError)
                {
                    <p class="govuk-error-message">
                        <span class="govuk-visually-hidden">Error:</span> @ViewData.ModelState["Applications"]?.Errors.FirstOrDefault()?.ErrorMessage
                    </p>
                }

                @if (Model.Applications.Count == 0)
                {
                    <p class="govuk-body">This user is not assigned to any applications.</p>
                }
                else
                {
                    @foreach (var item in Model.Applications.Select((application, index) => new { application, index }))
                    {
                        var application = item.application;
                        var index = item.index;
                        var roleErrorKey = $"Applications[{index}].SelectedRoleId";
                        var hasRoleError = ViewData.ModelState.ContainsKey(roleErrorKey) &&
                                           ViewData.ModelState[roleErrorKey]?.Errors.Count > 0;

                        <div class="app-application-role-card govuk-!-margin-bottom-6">
                            <h2 class="govuk-heading-m">@application.ApplicationName</h2>
                            <p class="govuk-body">@application.ApplicationDescription</p>

                            <input type="hidden" name="Applications[@index].OrganisationApplicationId" value="@application.OrganisationApplicationId" />

                            <div class="govuk-form-group @(hasRoleError ? "govuk-form-group--error" : "")">
                                <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Select a role</h3>
                                @if (hasRoleError)
                                {
                                    <p class="govuk-error-message">
                                        <span class="govuk-visually-hidden">Error:</span> @ViewData.ModelState[roleErrorKey]?.Errors.FirstOrDefault()?.ErrorMessage
                                    </p>
                                }

                                @if (application.Roles.Count > 0)
                                {
                                    <details class="govuk-details govuk-!-margin-bottom-3" data-module="govuk-details">
                                        <summary class="govuk-details__summary">
                                            <span class="govuk-details__summary-text">What can each role do?</span>
                                        </summary>
                                        <div class="govuk-details__text">
                                            <ul class="govuk-list govuk-list--bullet">
                                                @foreach (var role in application.Roles)
                                                {
                                                    <li><strong>@role.Name:</strong> @(string.IsNullOrWhiteSpace(role.Description) ? "No description available." : role.Description)</li>
                                                }
                                            </ul>
                                        </div>
                                    </details>

                                    <div class="govuk-radios" data-module="govuk-radios">
                                        @foreach (var role in application.Roles)
                                        {
                                            var isRoleSelected = application.SelectedRoleId == role.Id;
                                            <div class="govuk-radios__item">
                                                <input class="govuk-radios__input" id="applications-@index-role-@role.Id" name="Applications[@index].SelectedRoleId" type="radio" value="@role.Id" checked="@isRoleSelected">
                                                <label class="govuk-label govuk-radios__label" for="applications-@index-role-@role.Id">@role.Name</label>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="govuk-body">No roles available for this application.</p>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @if (Model.Applications.Count > 0)
            {
                <div class="govuk-button-group">
                    <button class="govuk-button" data-module="govuk-button">Continue</button>
                    <a class="govuk-link" href="/organisation/@Model.OrganisationSlug">Cancel</a>
                </div>
            }
        </form>
    </div>
</div>
