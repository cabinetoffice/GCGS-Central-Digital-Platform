{
  "Version": "dev",
  "Logging": {
    "Console": false,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "SharedSessions": true,
    "ContentSecurityPolicy": true,
    "DiagnosticPage": {
      "Enabled": false,
      "Path": ""
    }
  },
  "ForwardedHeaders": {
    "KnownNetwork": ""
  },
  "UserManagementApi": {
    "BaseUrl": "http://localhost:8066"
  },
  "OneLogin": {
    "Authority": "https://oidc.integration.account.gov.uk",
    "ClientId": "",
    "PrivateKey": "",
    "AccountUrl": "",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Organisation": {
    "Authority": "http://localhost:8092"
  },
  "SirsiService": {
    "ServiceBaseUrl": ""
  },
  "FtsService": {
    "ServiceBaseUrl": ""
  },
  "Aws": {
    "CloudWatch": {
      "LogGroup": "/ecs/user-management-app",
      "LogStream": "serilog"
    },
    "ElastiCache": {
      "Hostname": "localhost",
      "Port": "6379"
    },
    "SystemManager": {
      "DataProtectionPrefix": "/CDP/DataProtection"
    }
  },
  "SessionTimeoutInMinutes": 60
}
