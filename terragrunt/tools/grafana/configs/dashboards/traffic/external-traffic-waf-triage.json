{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "cloudwatch",
        "uid": "CLOUDWATCH"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Top Threat Actors (by IP)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "CLOUDWATCH"
          },
          "logGroups": [
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi:*",
              "name": "aws-waf-logs-cdp-sirsi"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-php:*",
              "name": "aws-waf-logs-cdp-sirsi-php"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-fts:*",
              "name": "aws-waf-logs-cdp-sirsi-fts"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-tools:*",
              "name": "aws-waf-logs-cdp-sirsi-tools"
            }
          ],
          "queryMode": "Logs",
          "refId": "A",
          "region": "default",
          "queryLanguage": "CWLI",
          "expression": "fields @timestamp\n| parse @message /\"webaclId\":\"(?<webaclId>[^\"]+)\"/\n| parse @message /\"clientIp\":\"(?<ip>[^\"]+)\"/\n| parse @message /\"country\":\"(?<country>[^\"]+)\"/\n| parse @message /\"action\":\"(?<action>[^\"]+)\"/\n| parse @message /\"terminatingRuleId\":\"(?<terminatingRuleId>[^\"]+)\"/\n| filter webaclId like /$web_acl/\n| filter @log like /$waf_log_group/\n| filter action like /$action_filter/\n| filter ip like /$ip_filter/\n| filter country like /$country_filter/\n| stats count() as requests, min(@timestamp) as first_seen, max(@timestamp) as last_seen by ip, country, action, terminatingRuleId\n| limit 200\n| sort requests desc"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true,
              "@message": true,
              "Time": true
            },
            "indexByName": {
              "ip": 0,
              "country": 1,
              "action": 2,
              "terminatingRuleId": 3,
              "requests": 4,
              "first_seen": 5,
              "last_seen": 6
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "requests",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^(?:cdp-sirsi-)?(?:php-|fts-|tools-|cfs-)?(.*)$",
            "renamePattern": "$1",
            "fields": [
              "terminatingRuleId"
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ip"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Filter by IP",
                    "url": "${__url.path}?var-ip_filter=${__value.raw}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "datasource": {
        "type": "cloudwatch",
        "uid": "CLOUDWATCH"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 2,
      "title": "Top URIs for Selected IP",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "CLOUDWATCH"
          },
          "logGroups": [
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi:*",
              "name": "aws-waf-logs-cdp-sirsi"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-php:*",
              "name": "aws-waf-logs-cdp-sirsi-php"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-fts:*",
              "name": "aws-waf-logs-cdp-sirsi-fts"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-tools:*",
              "name": "aws-waf-logs-cdp-sirsi-tools"
            }
          ],
          "queryMode": "Logs",
          "refId": "A",
          "region": "default",
          "queryLanguage": "CWLI",
          "expression": "fields @timestamp\n| parse @message /\"webaclId\":\"(?<webaclId>[^\"]+)\"/\n| parse @message /\"clientIp\":\"(?<ip>[^\"]+)\"/\n| parse @message /\"uri\":\"(?<uri>[^\"]+)\"/\n| parse @message /\"action\":\"(?<action>[^\"]+)\"/\n| parse @message /\"rule\":\"(?<rule>[^\"]+)\"/\n| filter webaclId like /$web_acl/\n| filter @log like /$waf_log_group/\n| filter action like /$action_filter/\n| filter ip like /$ip_filter/\n| stats count() as requests by uri, action, rule\n| sort requests desc\n| limit 100"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true,
              "@message": true,
              "Time": true
            },
            "indexByName": {
              "uri": 0,
              "action": 1,
              "rule": 2,
              "requests": 3
            }
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^(?:cdp-sirsi-)?(?:php-|fts-|tools-|cfs-)?(.*)$",
            "renamePattern": "$1",
            "fields": [
              "rule"
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": [
                {
                  "value": "Default_Action",
                  "text": "-"
                }
              ]
            }
          ]
        }
      }
    }
  ],
  "refresh": "30s",
