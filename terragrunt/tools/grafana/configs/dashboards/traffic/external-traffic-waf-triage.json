      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "CLOUDWATCH"
          },
          "expression": "fields @timestamp\n| parse @message /\"webaclId\":\"(?<webaclId>[^\"]+)\"/\n| parse @message /\"clientIp\":\"(?<ip>[^\"]+)\"/\n| parse @message /\"country\":\"(?<country>[^\"]+)\"/\n| parse @message /\"action\":\"(?<action>[^\"]+)\"/\n| parse @message /\"terminatingRuleId\":\"(?<terminatingRuleId>[^\"]+)\"/\n| filter webaclId like /$web_acl/\n| filter @log like /$waf_log_group/\n| filter action like /$action_filter/\n| filter ip like /$ip_filter/\n| filter country like /$country_filter/\n| stats count() as requests, min(@timestamp) as first_seen, max(@timestamp) as last_seen by ip, country, action, terminatingRuleId\n| limit 200\n| sort requests desc",
          "logGroups": [
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi:*",
              "name": "aws-waf-logs-cdp-sirsi"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-php:*",
              "name": "aws-waf-logs-cdp-sirsi-php"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-fts:*",
              "name": "aws-waf-logs-cdp-sirsi-fts"
            },
            {
              "accountId": "GRAFANA_CLOUDWATCH_ACCOUNT_ID",
              "arn": "arn:aws:logs:eu-west-2:GRAFANA_CLOUDWATCH_ACCOUNT_ID:log-group:aws-waf-logs-cdp-sirsi-tools:*",
              "name": "aws-waf-logs-cdp-sirsi-tools"
            }
          ],
          "queryLanguage": "CWLI",
          "queryMode": "Logs",
          "refId": "A",
          "region": "default"
        }
      ],
      "title": "Top Threat Actors (by IP)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "@message": true,
              "Time": true,
              "Value": true
            },
            "indexByName": {
              "action": 1,
              "country": 2,
              "first_seen": 5,
              "ip": 4,
              "last_seen": 6,
              "requests": 0,
              "rule": 3,
              "terminatingRuleId": 3
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "desc": true,
                "field": "requests"
              }
            ]
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "fields": [
              "terminatingRuleId"
            ],
            "regex": "^(?:cdp-sirsi-)?(?:php-|fts-|tools-|cfs-)?(.*)$",
            "renamePattern": "$1"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^terminatingRuleId$",
            "renamePattern": "rule"
          }
        }
      ],
      "type": "table"
    },
