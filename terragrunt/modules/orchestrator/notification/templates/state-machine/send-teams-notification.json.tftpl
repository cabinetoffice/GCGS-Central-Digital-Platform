{
  "Comment": "State machine for sending Teams notifications via Lambda",
  "StartAt": "Invoke Teams Notifier",
  "States": {
    "Invoke Teams Notifier": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "${teams_notifier_lambda_arn}",
        "Payload.$": "$"
      },
      "ResultPath": "$.teamsNotifier",
      "End": true
    }
  }
}
