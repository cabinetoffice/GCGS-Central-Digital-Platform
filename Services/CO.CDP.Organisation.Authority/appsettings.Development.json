{
  "Logging": {
    "Console": true,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Issuer": "http://localhost:8092",
  "OrganisationApiService": "http://localhost:8080",
  "OrganisationInformationDatabase": {
    "Server": "localhost",
