{
  "Logging": {
    "Console": false,
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Version": "dev",
  "Issuer": "",
  "PrivateKey": "",
  "OneLogin:Authority": "",
  "ForwardedHeaders": {
    "KnownNetwork": ""
  },
  "OrganisationInformationDatabase": {
    "Server": "localhost",
    "Database": "cdp",
    "Username": "cdp_user",
    "Password": "cdp123",
    "MaxPoolSize": 300
  },
  "Features": {
    "SwaggerUI": false,
    "ClaimsApiEnabled": true
  },
  "TokenExpiry": {
    "AccessTokenSeconds": 3600,
    "RefreshTokenSeconds": 86400
  },
  "SessionTimeoutInMinutes": 60,
  "Aws": {
    "CloudWatch": {
      "LogGroup": "/ecs/authority",
      "LogStream": "serilog"
    }
  }
}
