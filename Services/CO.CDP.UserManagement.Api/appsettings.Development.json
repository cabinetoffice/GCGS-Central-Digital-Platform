{
  "Logging": {
    "Console": true,
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "UserManagementDatabase": {
    "Server": "localhost",
    "Database": "cdp",
    "Username": "cdp_user",
    "Password": "cdp123"
  },
  "PersonService": "http://localhost:8084",
  "OrganisationService": "http://localhost:8082",
  "Organisation:Authority": "http://localhost:8092",
  "OrganisationInformationDatabase": {
    "Server": "localhost",
    "Database": "cdp",
    "Username": "cdp_user",
    "Password": "cdp123",
    "MaxPoolSize": 300
  },
  "Aws": {
    "Region": "eu-west-2",
    "Credentials": {
      "AccessKeyId": "test",
      "SecretAccessKey": "test"
    },
    "ServiceURL": "http://localhost:4566",
    "ElastiCache": {
      "Hostname": "localhost",
      "Port": "6379"
    },
    "OutboxRoutes": [
      {
        "MessageType": "PersonRemovedFromOrganisation",
        "QueueUrl": "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/organisation.fifo",
        "MessageGroupId": "Organisation"
      },
      {
        "MessageType": "PersonScopesUpdated",
        "QueueUrl": "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/organisation.fifo",
        "MessageGroupId": "Organisation"
      }
    ],
    "SqsDispatcher": {
      "QueueUrl": "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/user-management.fifo",
      "MaxNumberOfMessages": 10,
      "WaitTimeSeconds": 20
    }
  },
  "Features": {
    "SwaggerUI": true
  },
  "ServiceKey": {
    "ApiKey": "test-api-key"
  }
}
