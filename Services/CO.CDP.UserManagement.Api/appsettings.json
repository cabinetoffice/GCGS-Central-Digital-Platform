{
  "Version": "dev",
  "Logging": {
    "Console": false,
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ForwardedHeaders": {
    "KnownNetwork": ""
  },
  "UserManagementDatabase": {
    "Server": "localhost",
    "Database": "cdp",
    "Username": "cdp_user",
    "Password": "cdp123",
    "MaxPoolSize": 300
  },
  "OrganisationInformationDatabase": {
    "Server": "localhost",
    "Database": "cdp",
    "Username": "cdp_user",
    "Password": "cdp123",
    "MaxPoolSize": 300
  },
  "PersonService": "http://localhost:8084",
  "OrganisationService": "http://localhost:8082",
  "Organisation:Authority": "http://localhost:8092",
  "Aws": {
    "ElastiCache": {
      "Hostname": "localhost",
      "Port": "6379"
    },
    "CloudWatch": {
      "LogGroup": "/ecs/user-management-api",
      "LogStream": "serilog"
    },
    "SqsPublisher": {
      "QueueUrl": "",
      "MessageGroupId": "UserManagement",
      "Outbox": {
        "BatchSize": 10,
        "ExecutionInterval": "00:00:10"
      }
    }
  },
  "Features": {
    "SwaggerUI": false
  },
  "ServiceKey": {
    "ApiKey": "test-api-key"
  },
  "AllowedHosts": "*"
}
